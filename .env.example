# ============================================================================
# DATABASE — Supabase Postgres (Free Tier)
# ============================================================================
# Create a free project at https://supabase.com -> Project Settings -> Database
# Use the "Connection Pooling" URI for DATABASE_URL (pgbouncer, port 6543)
# and the "Direct connection" URI for DIRECT_URL (port 5432, used by migrations).
DATABASE_URL="postgresql://postgres.xxxxxxxx:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:<password>@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ============================================================================
# AUTH — Supabase Auth (Free Tier)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================================
# LLM — Local inference via Ollama (free, open-source, no API key)
# Install: https://ollama.com  →  ollama pull qwen2.5:7b-instruct
# ============================================================================
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b-instruct"
# Fallback chain, tried in order if the primary model is not pulled locally:
OLLAMA_FALLBACK_MODELS="gemma2:9b,llama3.2:3b-instruct,mistral:7b-instruct"
# If true, agents run entirely on deterministic algorithms and skip the
# LLM explanation/summary layer (useful for CI or machines without Ollama).
LLM_DISABLED="false"

# ============================================================================
# EXTERNAL FREE APIs (no key required)
# ============================================================================
WEATHER_API_BASE_URL="https://api.open-meteo.com/v1/forecast"
HOLIDAY_API_BASE_URL="https://date.nager.at/api/v3/PublicHolidays"
PROJECT_SITE_LAT="17.4065"
PROJECT_SITE_LON="78.4772"
PROJECT_COUNTRY_CODE="IN"

# ============================================================================
# APP
# ============================================================================
NEXT_PUBLIC_APP_NAME="EPC Project Intelligence"
NODE_ENV="development"
